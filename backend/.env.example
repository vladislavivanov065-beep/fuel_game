DATABASE_URL=postgresql+asyncpg://gaswars:gaswars@localhost:5432/gaswars

# Список разрешённых origin для CORS: JSON-массив ("[\"https://a\",\"https://b\"]")
# или через запятую (https://a,https://b). В продакшене — домен фронтенда.
CORS_ORIGINS=http://localhost:5173

# true в продакшене, если backend и frontend на разных доменах/поддоменах
# (тогда SameSite=None, что требует Secure=true) — иначе браузер не пришлёт
# cookie сессии при кросс-доменных запросах.
SESSION_COOKIE_SECURE=false

LOG_LEVEL=INFO
