{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "/app/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "preDeployCommand": "/app/.venv/bin/python -m scripts.release",
    "restartPolicyType": "ON_FAILURE"
  }
}
